			"versionNonce": 601,
			"isDeleted": false,
			"boundElements": null,
			"updated": 1,
			"link": null,
			"locked": false,
			"text": "CAREER PATH OUTPUT FIELDS\n\nFrom PlannerMetricsService:\n  period_miles (float)\n  quota_target (float, from config)\n  quota_percent (int, 0-100)\n  gap_miles (float, quota - actual)\n  status (success|warning|danger)\n  statusLabel (On Track|Progressing|Behind)\n  daily_miles[] (7-element Sun-Sat array)\n  streak_weeks (int, consecutive on-target)\n  last_week_miles (float)\n  days_since_last_edit (int)\n  pending_over_threshold (int)\n  overall_percent (float)\n  display_name (string)\n\nFrom Health Signal (AssessmentMonitor):\n  circuits[] { line_name, region,\n    completed_miles, total_miles,\n    permission_breakdown }\n\nFrom CoachingMessageGenerator:\n  coaching_message (nullable string)",
			"fontSize": 12,
			"fontFamily": 3,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": "box-career-fields",
			"originalText": "CAREER PATH OUTPUT FIELDS\n\nFrom PlannerMetricsService:\n  period_miles (float)\n  quota_target (float, from config)\n  quota_percent (int, 0-100)\n  gap_miles (float, quota - actual)\n  status (success|warning|danger)\n  statusLabel (On Track|Progressing|Behind)\n  daily_miles[] (7-element Sun-Sat array)\n  streak_weeks (int, consecutive on-target)\n  last_week_miles (float)\n  days_since_last_edit (int)\n  pending_over_threshold (int)\n  overall_percent (float)\n  display_name (string)\n\nFrom Health Signal (AssessmentMonitor):\n  circuits[] { line_name, region,\n    completed_miles, total_miles,\n    permission_breakdown }\n\nFrom CoachingMessageGenerator:\n  coaching_message (nullable string)",
			"autoResize": true,
			"lineHeight": 1.25,
			"index": "ax",
			"strokeStyle": "solid",
			"frameId": null,
			"hasTextLink": false,
