			"boundElements": null,
			"updated": 1,
			"link": null,
			"locked": false,
			"text": "DAILY PATH OUTPUT FIELDS\n\nFrom planner_daily_records (raw SQL):\n  dailyData {\n    dates[] (date strings)\n    series[] {\n      name (planner display name)\n      data[] (daily_miles per date)\n    }\n  }\n  summaryTable[] {\n    planner (display name)\n    total_miles, avg_per_day\n    peak_miles, peak_date\n    active_days\n  }\n  availablePlanners[] (dropdown list)\n  scopeYearTopPlanners[] (top 4)\n  scopeYearLabel (fiscal year range)",
			"fontSize": 12,
			"fontFamily": 3,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": "box-daily-fields",
			"originalText": "DAILY PATH OUTPUT FIELDS\n\nFrom planner_daily_records (raw SQL):\n  dailyData {\n    dates[] (date strings)\n    series[] {\n      name (planner display name)\n      data[] (daily_miles per date)\n    }\n  }\n  summaryTable[] {\n    planner (display name)\n    total_miles, avg_per_day\n    peak_miles, peak_date\n    active_days\n  }\n  availablePlanners[] (dropdown list)\n  scopeYearTopPlanners[] (top 4)\n  scopeYearLabel (fiscal year range)",
			"autoResize": true,
			"lineHeight": 1.25,
			"index": "az",
			"strokeStyle": "solid",
			"frameId": null,
