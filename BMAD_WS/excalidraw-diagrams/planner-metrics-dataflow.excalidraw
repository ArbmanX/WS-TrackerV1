			"boundElements": null,
			"updated": 1,
			"link": null,
			"locked": false,
			"text": "5.0 OVERVIEW - REQUIRED FIELDS\n\nplanners[] (per planner):\n  name, initials, display_name\n  period_miles, quota_target\n  quota_percent, gap_miles\n  status, statusLabel\n  daily_miles[] (sparkline bars)\n  streak_weeks (fire badge >= 2)\n  days_since_last_edit\n  pending_over_threshold\n  overall_percent\n  coaching_message (nullable)\n\nsummaryStats:\n  on_track (count of success planners)\n  total_aging (sum pending units)\n  total_miles (team period total)\n  team_avg_percent (avg quota %)\n\nperiodLabel (formatted date range)\n\nexpandedCircuits[] (on click):\n  line_name, region\n  completed_miles, total_miles\n  percent (progress bar)\n  permission_breakdown {\n    Approved, Pending, No Contact,\n    Refused, Deferred, PPL\n  }",
			"fontSize": 12,
			"fontFamily": 3,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": "box-overview-needs",
			"originalText": "5.0 OVERVIEW - REQUIRED FIELDS\n\nplanners[] (per planner):\n  name, initials, display_name\n  period_miles, quota_target\n  quota_percent, gap_miles\n  status, statusLabel\n  daily_miles[] (sparkline bars)\n  streak_weeks (fire badge >= 2)\n  days_since_last_edit\n  pending_over_threshold\n  overall_percent\n  coaching_message (nullable)\n\nsummaryStats:\n  on_track (count of success planners)\n  total_aging (sum pending units)\n  total_miles (team period total)\n  team_avg_percent (avg quota %)\n\nperiodLabel (formatted date range)\n\nexpandedCircuits[] (on click):\n  line_name, region\n  completed_miles, total_miles\n  percent (progress bar)\n  permission_breakdown {\n    Approved, Pending, No Contact,\n    Refused, Deferred, PPL\n  }",
